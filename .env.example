# The public host where clients will connect to this relay server.
# Used in `aac server join` — no trailing slash.
# Examples: http://192.168.1.100:9100, https://relay.example.com
AAC_HOST=http://localhost:9100

# Host port mapping (container always listens on 9100 internally)
AAC_PORT=9100

# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=aac

# S3 / MinIO object storage
# Large message bodies (> 64KB) are offloaded to S3. Included MinIO service
# provides this out of the box — change credentials in production.
AAC_S3_ACCESS_KEY_ID=minioadmin
AAC_S3_SECRET_ACCESS_KEY=minioadmin
AAC_S3_BUCKET=aac-messages
AAC_S3_REGION=us-east-1

# Path-style access (http://endpoint/bucket/key instead of http://bucket.endpoint/key).
# Auto-detected: non-AWS endpoints default to true. Set explicitly if needed.
# AAC_S3_FORCE_PATH_STYLE=true

# MinIO web console port (http://localhost:9001)
AAC_MINIO_CONSOLE_PORT=9001
