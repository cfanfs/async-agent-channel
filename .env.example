# The public host where clients will connect to this relay server.
# Used in `aac server join` — no trailing slash.
# Examples: http://192.168.1.100:9100, https://relay.example.com
AAC_HOST=http://localhost:9100

# Host port mapping (container always listens on 9100 internally)
AAC_PORT=9100

# PostgreSQL password (change in production!)
POSTGRES_PASSWORD=aac
